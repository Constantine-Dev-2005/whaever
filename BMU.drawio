        </mxCell>        <mxCell id="bmu-title" value="Блок Мікропрограмного Управління (БМУ) — Курсовий проект КВ-32" style="text;html=1;align=center;verticalAlign=middle;resizable=0;autosize=1;fontFamily=Times New Roman;fontSize=12;fontStyle=1;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
