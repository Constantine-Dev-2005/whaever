        <mxCell id="bmu-mcmd" value="Шина мікрокоманди D[55:0]&#xa;→ до БОД: поле I[8:0]&#xa;→ керування ALU, зсув, адреса РЗП" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontFamily=Times New Roman;fontSize=11;fillColor=#e8f4e8;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
