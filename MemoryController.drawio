              <mxCell id="mem-ttl" value="Структурна схема підсистеми пам'яті (ОЗП/ПЗП)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
