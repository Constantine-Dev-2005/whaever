        <mxCell id="mem-cpu" value="Процесор КВ-32&amp;#xA;─────────────────────────────&amp;#xA;Адресна шина: A[15:0] (вихід)&amp;#xA;  A[15:13] → К1533ИД7 (декодування CS)&amp;#xA;  A[12:0]  → ПЗП A[12:0]&amp;#xA;  A[10:0]  → ОЗП A[10:0]&amp;#xA;Шина даних: D[31:0] (двоспрямована)&amp;#xA;─────────────────────────────&amp;#xA;Керуючі сигнали:&amp;#xA;  /WR (зап., акт.LOW) → /WE ОЗП&amp;#xA;  /RD (чит., акт.LOW) → /OE ОЗП+ПЗП&amp;#xA;  /MREQ (запит пам'яті) → G1 дешифр." style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-1700" y="-600" width="360" height="320" as="geometry" />
        </mxCell>
        <mxCell id="mem-dec" value="DD1 К1533ИД7 — DIP-16&amp;#xA;Дешифратор адреси 3→8 (аналог 74LS138)&amp;#xA;─────────────────────────────&amp;#xA;Адресні входи: A(1), B(2), C(3) ← A[13–15]&amp;#xA;Дозвіл: /G2A(4)→GND, /G2B(5)→GND, G1(6)→+5В&amp;#xA;─────────────────────────────&amp;#xA;Виходи (активний рівень LOW):&amp;#xA;  /Y0(15) → /CS0 → ОЗП Банк1 (A[15:13]=000)&amp;#xA;  /Y1(14) → /CS1 → ОЗП Банк2 (A[15:13]=001)&amp;#xA;  /Y2(13) → /CS2 → ПЗП Банк1 (A[15:13]=010)&amp;#xA;  /Y3(12) → /CS3 → ПЗП Банк2 (A[15:13]=011)&amp;#xA;  /Y4–/Y7(11–8) → NC або резерв&amp;#xA;─────────────────────────────&amp;#xA;VCC(16)=+5В, GND(8)&amp;#xA;C1=100нФ розв'язка" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-1200" y="-500" width="320" height="380" as="geometry" />
        </mxCell>
        <mxCell id="mem-ram1" value="ОЗП Банк 1: 4 × К537РУ8 — DIP-24 кожна&amp;#xA;Статична SRAM 2К×8, підсумок 2К×32 біт&amp;#xA;─────────────────────────────&amp;#xA;Адресний вхід: A[10:0](1–11) ← шина A[10:0]&amp;#xA;Вибір: /CS(18)← /CS0 від К1533ИД7&amp;#xA;Запис: /WE(21) ← /WR від процесора&amp;#xA;Читання: /OE(22)→+5В↑R1(1кОм), знімається при /RD&amp;#xA;─────────────────────────────&amp;#xA;Шина даних (двоспрямована):&amp;#xA;  К537РУ8 №1: D[7:0](13–20) ↔ DB[7:0]&amp;#xA;  К537РУ8 №2: D[7:0](13–20) ↔ DB[15:8]&amp;#xA;  К537РУ8 №3: D[7:0](13–20) ↔ DB[23:16]&amp;#xA;  К537РУ8 №4: D[7:0](13–20) ↔ DB[31:24]&amp;#xA;─────────────────────────────&amp;#xA;VCC(24)=+5В, GND(12) (4 мікросхеми)&amp;#xA;C2–C5=100нФ розв'язка (по одній)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-700" y="-700" width="400" height="400" as="geometry" />
        </mxCell>
        <mxCell id="mem-ram2" value="ОЗП Банк 2: 4 × К537РУ8 — DIP-24 кожна&amp;#xA;Статична SRAM 2К×8, підсумок 2К×32 біт (верхня половина адрес)&amp;#xA;─────────────────────────────&amp;#xA;Адресний вхід: A[10:0](1–11) ← шина A[10:0]&amp;#xA;Вибір: /CS(18)← /CS1 від К1533ИД7&amp;#xA;Запис: /WE(21) ← /WR від процесора&amp;#xA;Читання: /OE(22)→+5В↑R2(1кОм), знімається при /RD&amp;#xA;─────────────────────────────&amp;#xA;Шина даних (двоспрямована):&amp;#xA;  К537РУ8 №5: D[7:0](13–20) ↔ DB[7:0]&amp;#xA;  К537РУ8 №6: D[7:0](13–20) ↔ DB[15:8]&amp;#xA;  К537РУ8 №7: D[7:0](13–20) ↔ DB[23:16]&amp;#xA;  К537РУ8 №8: D[7:0](13–20) ↔ DB[31:24]&amp;#xA;─────────────────────────────&amp;#xA;VCC(24)=+5В, GND(12) (4 мікросхеми)&amp;#xA;C6–C9=100нФ розв'язка (по одній)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-700" y="-220" width="400" height="400" as="geometry" />
        </mxCell>
        <mxCell id="mem-rom1" value="ПЗП Банк 1: 4 × К596РЕ1 — DIP-28 кожна&amp;#xA;EPROM 8К×8, підсумок 8К×32 біт&amp;#xA;─────────────────────────────&amp;#xA;Адресний вхід: A[12:0](1–13) ← шина A[12:0]&amp;#xA;Вибір: /CE(20)← /CS2 від К1533ИД7&amp;#xA;Дозвіл виходу: /OE(22)→+5В↑R3(1кОм), знімається при /RD&amp;#xA;─────────────────────────────&amp;#xA;Шина даних (тільки читання):&amp;#xA;  К596РЕ1 №1: O[7:0](11–19) → DB[7:0]&amp;#xA;  К596РЕ1 №2: O[7:0](11–19) → DB[15:8]&amp;#xA;  К596РЕ1 №3: O[7:0](11–19) → DB[23:16]&amp;#xA;  К596РЕ1 №4: O[7:0](11–19) → DB[31:24]&amp;#xA;─────────────────────────────&amp;#xA;VCC(28)=+5В, GND(14) (4 мікросхеми)&amp;#xA;C10–C13=100нФ розв'язка (по одній)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-200" y="-700" width="400" height="400" as="geometry" />
        </mxCell>
        <mxCell id="mem-rom2" value="ПЗП Банк 2: 4 × К596РЕ1 — DIP-28 кожна&amp;#xA;EPROM 8К×8, підсумок 8К×32 біт (верхня половина адрес ПЗП)&amp;#xA;─────────────────────────────&amp;#xA;Адресний вхід: A[12:0](1–13) ← шина A[12:0]&amp;#xA;Вибір: /CE(20)← /CS3 від К1533ИД7&amp;#xA;Дозвіл виходу: /OE(22)→+5В↑R4(1кОм), знімається при /RD&amp;#xA;─────────────────────────────&amp;#xA;Шина даних (тільки читання):&amp;#xA;  К596РЕ1 №5: O[7:0](11–19) → DB[7:0]&amp;#xA;  К596РЕ1 №6: O[7:0](11–19) → DB[15:8]&amp;#xA;  К596РЕ1 №7: O[7:0](11–19) → DB[23:16]&amp;#xA;  К596РЕ1 №8: O[7:0](11–19) → DB[31:24]&amp;#xA;─────────────────────────────&amp;#xA;VCC(28)=+5В, GND(14) (4 мікросхеми)&amp;#xA;C14–C17=100нФ розв'язка (по одній)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
