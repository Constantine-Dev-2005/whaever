        <!-- === БЛОК ПАСИВНИХ КОМПОНЕНТІВ === -->
        <mxCell id="mem-passives" value="ПАСИВНІ КОМПОНЕНТИ КПМ&amp;#xA;─────────────────────────────&amp;#xA;Розв'язувальні конденсатори (100нФ, 50В, X7R):&amp;#xA;  C1  — DD1 К1533ИД7 VCC(16)–GND(8)&amp;#xA;  C2  — К537РУ8 №1 VCC(24)–GND(12) [Б1]&amp;#xA;  C3  — К537РУ8 №2 VCC(24)–GND(12) [Б1]&amp;#xA;  C4  — К537РУ8 №3 VCC(24)–GND(12) [Б1]&amp;#xA;  C5  — К537РУ8 №4 VCC(24)–GND(12) [Б1]&amp;#xA;  C6  — К537РУ8 №5 VCC(24)–GND(12) [Б2]&amp;#xA;  C7  — К537РУ8 №6 VCC(24)–GND(12) [Б2]&amp;#xA;  C8  — К537РУ8 №7 VCC(24)–GND(12) [Б2]&amp;#xA;  C9  — К537РУ8 №8 VCC(24)–GND(12) [Б2]&amp;#xA;  C10 — К596РЕ1 №1 VCC(28)–GND(14) [Б3]&amp;#xA;  C11 — К596РЕ1 №2 VCC(28)–GND(14) [Б3]&amp;#xA;  C12 — К596РЕ1 №3 VCC(28)–GND(14) [Б3]&amp;#xA;  C13 — К596РЕ1 №4 VCC(28)–GND(14) [Б3]&amp;#xA;  C14 — К596РЕ1 №5 VCC(28)–GND(14) [Б4]&amp;#xA;  C15 — К596РЕ1 №6 VCC(28)–GND(14) [Б4]&amp;#xA;  C16 — К596РЕ1 №7 VCC(28)–GND(14) [Б4]&amp;#xA;  C17 — К596РЕ1 №8 VCC(28)–GND(14) [Б4]&amp;#xA;  C18 — 10мкФ/16В (груповий по +5В шині)&amp;#xA;─────────────────────────────&amp;#xA;Підтягувальні резистори (+5В, 0.25Вт, 1кОм):&amp;#xA;  R1 — /OE ОЗП Банк1 (4×К537РУ8 паралельно)&amp;#xA;  R2 — /OE ОЗП Банк2 (4×К537РУ8 паралельно)&amp;#xA;  R3 — /OE ПЗП Банк1 (4×К596РЕ1 паралельно)&amp;#xA;  R4 — /OE ПЗП Банк2 (4×К596РЕ1 паралельно)&amp;#xA;─────────────────────────────&amp;#xA;XP1 — роз'єм живлення +5В/GND (2-конт.)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#FFF9C4;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="360" y="-700" width="400" height="780" as="geometry" />
        </mxCell>

        <!-- === ЧАСОВІ ПАРАМЕТРИ === -->
        <mxCell id="mem-timing" value="ЧАСОВІ ПАРАМЕТРИ КПМ&amp;#xA;─────────────────────────────&amp;#xA;К537РУ8 (SRAM):&amp;#xA;  t_acc (A→D) = 120 нс (max)&amp;#xA;  t_ce (/CS→D) = 120 нс&amp;#xA;  t_wr (запис) = 70 нс (min WE LOW)&amp;#xA;─────────────────────────────&amp;#xA;К596РЕ1 (EPROM):&amp;#xA;  t_acc (A→O) = 200 нс (max)&amp;#xA;  t_ce (/CE→O) = 200 нс&amp;#xA;─────────────────────────────&amp;#xA;Процесор КВ-32: f_CLK=5МГц, T=200нс&amp;#xA;Цикл читання ОЗП: 1 такт (200нс &gt; 120нс ✓)&amp;#xA;Цикл читання ПЗП: 2 такти (400нс &gt; 200нс ✓)&amp;#xA;  → 1 такт очікування (WAIT) для ПЗП&amp;#xA;─────────────────────────────&amp;#xA;Ємність ОЗП: 2×2К×32 = 16 КБ&amp;#xA;Ємність ПЗП: 2×8К×32 = 64 КБ" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#E8F4FD;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="360" y="100" width="400" height="380" as="geometry" />
