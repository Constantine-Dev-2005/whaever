        <mxCell id="bmu-kop" value="RG1 Регістр КОП&amp;#xA;(Код операції)&amp;#xA;Q[8:0] → D[8:0]" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-1700" y="-600" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bmu-fam" value="DD1 К1804ВУ4 (ФАМ) — DIP-40&amp;#xA;Формувач адреси мікрокоманд (Am2910-аналог)&amp;#xA;─────────────────────────────&amp;#xA;Вхід КОП: I[3:0](1–4) ←D[8:0] від RG1&amp;#xA;Прямий вхід: D[8:0](9–17) ← КОП/константа&amp;#xA;Умова: CC(19) ←MUX, /CCEN(18)&amp;#xA;Тактування: CP(21) ←CLK&amp;#xA;Скидання: /R(22) →+5В ↑R1(4.7кОм)&amp;#xA;Лічильник: /CI(34)→+5В↑R2(4.7кОм), CO(33)→DD4&amp;#xA;Стек: /FULL(35)→+5В↑R3(4.7кОм)&amp;#xA;Розгалуження: /MAP(6)→GND, /VECT(7)→+5В↑R4, /PL(8)&amp;#xA;Рег.завант.: RLD(5) ←зовн.керув.&amp;#xA;─────────────────────────────&amp;#xA;Вихід адреси: Y[8:0](24–32) →DD2-DD8 A[8:0]&amp;#xA;Управл.вих.: /OE(23)→GND (постійно ввімкн.)&amp;#xA;─────────────────────────────&amp;#xA;Живлення: VCC(40)=+5В, GND(20)&amp;#xA;Розв'язка: C1=100нФ між VCC(40)–GND(20)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-1300" y="-700" width="480" height="380" as="geometry" />
        </mxCell>
        <mxCell id="bmu-mpp" value="DD2–DD8: 7 × КР556РТ6 (МПП) — DIP-24 кожна&amp;#xA;Мікропрограмна пам'ять: 512 слів × 56 біт&amp;#xA;─────────────────────────────&amp;#xA;Адресний вхід: A[8:0](1–9) ← DD1 Y[8:0]&amp;#xA;Вибір мікросхеми: /CE(10)→GND (завжди акт.)&amp;#xA;Дозвіл виходу: /OE(11)→+5В↑R5(1кОм) або GND&amp;#xA;─────────────────────────────&amp;#xA;Вихід даних O[7:0]:&amp;#xA;  DD2: O[7:0] → шина мікрокоманди [7:0]&amp;#xA;  DD3: O[7:0] → шина мікрокоманди [15:8]&amp;#xA;  DD4: O[7:0] → I[8:1] до DD1 та БОД&amp;#xA;  DD5: O[7:0] → SH[2:0]+CTL[4:0] до БОД&amp;#xA;  DD6-DD8: O[7:0] → поля керув.мікрооперацій&amp;#xA;─────────────────────────────&amp;#xA;Живлення: VCC(24)=+5В, GND(12)&amp;#xA;Розв'язка: C2–C8=100нФ (по одній на мікросхему)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-1300" y="-250" width="480" height="380" as="geometry" />
        </mxCell>
        <mxCell id="bmu-ccmux" value="DD9 К155КП1 (MUX умов CC)&amp;#xA;16→1 мультиплексор (або К1533КП2)&amp;#xA;─────────────────────────────&amp;#xA;Входи даних D[15:0](1–16):&amp;#xA;  D0←R0[31] (знаковий біт)&amp;#xA;  D1←OVR (переповнення)&amp;#xA;  D2←Cn+4 (перенос)&amp;#xA;  D3–D15←GND або інші умови&amp;#xA;Вибір каналу: S[3:0] ←поле SH[2:0] мікрокоманди&amp;#xA;Вихід: Z(17) → CC вх. DD1(К1804ВУ4)&amp;#xA;─────────────────────────────&amp;#xA;VCC(16)=+5В, GND(8)&amp;#xA;C9=100нФ розв'язка" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-600" y="-700" width="280" height="260" as="geometry" />
        </mxCell>
        <mxCell id="bmu-ctr" value="DD10 К1533ИЕ7 (Лічильник циклів ділення)&amp;#xA;16-розрядний лічильник / 4×К1533ИЕ7 4-біт&amp;#xA;─────────────────────────────&amp;#xA;Завантаження: /LD(9)←мікрокоманда, D[3:0](3–6)←32&amp;#xA;Тактування: CP(2)←CLK&amp;#xA;Дозвіл рахунку: /CEP(7), /CET(10)←керування&amp;#xA;Вихід переносу: /TC(15)→DD1 /CI (ознака CT=0)&amp;#xA;─────────────────────────────&amp;#xA;VCC(16)=+5В, GND(8)&amp;#xA;C10=100нФ розв'язка" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-600" y="-370" width="280" height="240" as="geometry" />
        </mxCell>
        <mxCell id="bmu-mcmd" value="Шина мікрокоманди D[55:0]&amp;#xA;→ I[8:0], SH[2:0] до БОД" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-1300" y="100" width="400" height="80" as="geometry" />
        </mxCell>
        <mxCell id="bmu-sign" value="Сигнал знаку R0[31]&amp;#xA;(з БОД, bit31)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
          <mxGeometry x="-600" y="-900" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="bmu-clk" value="CLK" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
