              <mxCell id="bmu-ttl" value="БМУ. Схема електрична принципова (мікропрограмне керування)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
