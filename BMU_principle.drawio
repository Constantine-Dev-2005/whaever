        <mxCell id="bmu-sign-mux" value="R0[31]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;startArrow=none;startFill=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="bmu-sign" target="bmu-ccmux" parent="rYKlLN2ti9XnYYLPjGYp-1">
