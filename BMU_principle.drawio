        <mxCell id="bmu-passives" value="ПАСИВНІ КОМПОНЕНТИ БМУ&amp;#xA;─────────────────────────────&amp;#xA;Розв'язувальні конденсатори (100нФ, 50В, X7R):&amp;#xA;  C1 — DD1 VCC(40)–GND(20)&amp;#xA;  C2 — DD2 VCC(24)–GND(12)&amp;#xA;  C3 — DD3 VCC(24)–GND(12)&amp;#xA;  C4 — DD4 VCC(24)–GND(12)&amp;#xA;  C5 — DD5 VCC(24)–GND(12)&amp;#xA;  C6 — DD6 VCC(24)–GND(12)&amp;#xA;  C7 — DD7 VCC(24)–GND(12)&amp;#xA;  C8 — DD8 VCC(24)–GND(12)&amp;#xA;  C9 — DD9 VCC(16)–GND(8)&amp;#xA;  C10 — DD10 VCC(16)–GND(8)&amp;#xA;  C11 — 10мкФ/16В (груповий по +5В шині)&amp;#xA;─────────────────────────────&amp;#xA;Підтягувальні резистори (+5В, 0.25Вт):&amp;#xA;  R1=4.7кОм — DD1 /R(22) до VCC&amp;#xA;  R2=4.7кОм — DD1 /CI(34) до VCC&amp;#xA;  R3=4.7кОм — DD1 /FULL(35) до VCC&amp;#xA;  R4=4.7кОм — DD1 /VECT(7) до VCC&amp;#xA;  R5=1кОм — DD2-DD8 /OE(11) до VCC&amp;#xA;─────────────────────────────&amp;#xA;XP1 — роз'єм живлення +5В/GND (2-конт.)" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#FFF9C4;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
