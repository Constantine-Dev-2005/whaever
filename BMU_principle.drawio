        <!-- === БЛОК ЧАСОВИХ ПАРАМЕТРІВ === -->
        <mxCell id="bmu-timing" value="ЧАСОВІ ПАРАМЕТРИ БМУ&amp;#xA;─────────────────────────────&amp;#xA;К1804ВУ4 (Am2910):&amp;#xA;  t_pd (Y→output) = 35 нс&amp;#xA;  t_setup (D,CC→CP↑) = 15 нс&amp;#xA;  t_hold = 5 нс&amp;#xA;─────────────────────────────&amp;#xA;КР556РТ6 (PROM 512×8):&amp;#xA;  t_access (A→O) = 40 нс&amp;#xA;  t_ce (CE→O) = 40 нс&amp;#xA;─────────────────────────────&amp;#xA;T_min = t_pd(FAM) + t_acc(PROM) + t_setup&amp;#xA;       = 35 + 40 + 15 = 90 нс&amp;#xA;f_max = 1/90нс ≈ 11 МГц&amp;#xA;Обрана частота: f_CLK = 5 МГц (T=200нс)&amp;#xA;Запас часу: 200 - 90 = 110 нс" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#E8F4FD;" vertex="1" parent="rYKlLN2ti9XnYYLPjGYp-1">
